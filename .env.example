# Required in production
DJANGO_SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
DJANGO_ENVIRONMENT=production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database
DATABASE_NAME=farmvision
DATABASE_USER=farmvision_user
DATABASE_PASSWORD=change-this-strong-password
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
REDIS_PASSWORD=change-this-redis-password


# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Alert Configuration
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_EMAIL_RECIPIENTS=admin@your-domain.com,team@your-domain.com
ALERT_COOLDOWN_SECONDS=3600

# Email (SMTP — only required in production)
DEFAULT_FROM_EMAIL=Farm Vision <noreply@your-domain.com>
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# NodeODM Integration (set ODM_ENABLED=False to use pre-processed orthophotos)
ODM_ENABLED=True
ODM_HOST=localhost
ODM_PORT=3000
ODM_TOKEN=
